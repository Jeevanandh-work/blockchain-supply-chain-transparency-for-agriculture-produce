# Backend Environment Variables

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/supply-chain

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Blockchain
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=your_contract_address_after_deployment
BLOCKCHAIN_PRIVATE_KEY=your_private_key_for_transactions

# IPFS
IPFS_URL=http://127.0.0.1:5001
IPFS_GATEWAY=https://ipfs.io/ipfs

# Frontend
FRONTEND_URL=http://localhost:3000

# Role-specific keys (for development only)
FARMER_PRIVATE_KEY=your_farmer_private_key
USER_PRIVATE_KEY=your_user_private_key
